#!/usr/bin/env sh
set -eu

bundle_dir="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
helper="$bundle_dir/{{ .BinaryName }}"

if [ ! -f "$helper" ]; then
	printf 'Could not find helper binary at %s\n' "$helper" >&2
	exit 1
fi

# Silently strip the macOS web-download quarantine flag if it exists
if [ "$(uname)" = "Darwin" ]; then
  xattr -d com.apple.quarantine "$helper" 2>/dev/null || true
fi

chmod +x "$helper"
exec "$helper" "$@"
